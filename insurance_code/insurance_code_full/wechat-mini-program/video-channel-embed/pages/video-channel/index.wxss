.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx;
  background:
    radial-gradient(circle at top left, rgba(16, 185, 129, 0.16), transparent 38%),
    linear-gradient(180deg, #f1fbf6 0%, #ffffff 100%);
}

.hero {
  border-radius: 32rpx;
  padding: 32rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #0f766e 0%, #10b981 100%);
  box-shadow: 0 18rpx 48rpx rgba(16, 185, 129, 0.18);
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.title {
  margin-top: 20rpx;
  font-size: 56rpx;
  line-height: 1.18;
  font-weight: 800;
}

.desc {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.8;
  opacity: 0.96;
}

.card {
  margin-top: 28rpx;
  border-radius: 32rpx;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.08);
}

.meta-row + .meta-row {
  margin-top: 24rpx;
}

.meta-label {
  font-size: 24rpx;
  color: #64748b;
}

.meta-value {
  margin-top: 10rpx;
  font-size: 28rpx;
  line-height: 1.65;
  color: #0f172a;
  word-break: break-all;
}

.open-btn {
  margin-top: 32rpx;
  min-height: 92rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0f766e 0%, #10b981 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  box-shadow: 0 18rpx 36rpx rgba(15, 118, 110, 0.24);
}

.error-box {
  margin-top: 24rpx;
  border: 2rpx solid #fcd34d;
  border-radius: 24rpx;
  padding: 24rpx;
  background: #fff9db;
}

.error-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #92400e;
}

.error-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #92400e;
}

.helper-box {
  margin-top: 20rpx;
  border-radius: 24rpx;
  padding: 24rpx;
  background: #ecfeff;
}

.helper-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #155e75;
}

.helper-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #155e75;
}
