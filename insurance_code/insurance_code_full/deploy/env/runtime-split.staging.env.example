API_HOST=0.0.0.0
API_PORT=4000
API_GATEWAY_PORT=4100
API_USER_SERVICE_PORT=4101
API_POINTS_SERVICE_PORT=4102

STORAGE_BACKEND=postgres
DATABASE_URL=postgresql://<db_user>:<db_password>@<staging-db-host>:5432/insurance_runtime_staging
PGSSL=require

GATEWAY_V1_BASE_URL=http://v1-monolith:4000
GATEWAY_USER_SERVICE_URL=http://user-service:4101
GATEWAY_POINTS_SERVICE_URL=http://points-service:4102
GATEWAY_ENABLE_V2=true
GATEWAY_ENABLE_V1_FALLBACK=true
GATEWAY_FORCE_V1=false

VITE_API_BASE=https://<staging-gateway-host>
VITE_USER_SERVICE_BASE=https://<staging-gateway-host>
VITE_POINTS_SERVICE_BASE=https://<staging-gateway-host>
