# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Local API server
API_HOST="127.0.0.1"
API_PORT="4000"
CORS_ORIGIN="http://localhost:3000,http://localhost:3003,http://127.0.0.1:3003"
# Development only: fixed SMS code for local testing
DEV_SMS_CODE="123456"
# Enable only after a real WeChat public-account H5 OAuth appid/appsecret is configured.
WECHAT_H5_OAUTH_ENABLED="false"
WECHAT_H5_OAUTH_SCOPE="snsapi_base"

# Runtime storage backend: postgres | file
STORAGE_BACKEND="postgres"
# File backend paths: seed stays clean, runtime state writes to snapshot only
STATE_SEED_PATH="server/data/db.json"
STATE_RUNTIME_SNAPSHOT_PATH="server/data/runtime-snapshot.json"
# PostgreSQL connection string (authoritative dev template)
DATABASE_URL="postgresql://insurance:insurance@127.0.0.1:5432/insurance_runtime_dev"
# SSL is controlled separately via PGSSL; do not append sslmode to DATABASE_URL
PGSSL="disable"

# Ops API key for server-to-server learning course creation.
# Allows POST /api/p/learning/courses without Bearer/csrf when x-ops-api-key matches.
P_OPS_API_KEY=""
P_LEARNING_OPS_API_KEY=""

# Policy OCR provider: local | baidu_private | paddle_local
POLICY_OCR_PROVIDER="local"
# Optional standalone OCR microservice URL. Set to your local OCR node when app services run in cloud.
POLICY_OCR_SERVICE_URL="http://127.0.0.1:4105"
# Optional shared token between API and OCR microservice.
POLICY_OCR_SERVICE_TOKEN=""
# OCR service upstream timeout in milliseconds.
POLICY_OCR_SERVICE_TIMEOUT_MS="180000"
# Baidu private OCR endpoint, for example your intranet OCR gateway URL.
POLICY_OCR_BAIDU_PRIVATE_URL=""
# Optional auth token for the private OCR gateway.
POLICY_OCR_BAIDU_PRIVATE_ACCESS_TOKEN=""
# Token auth mode: none | query | bearer | header
POLICY_OCR_BAIDU_PRIVATE_AUTH_MODE="query"
# Custom header name when auth mode is header
POLICY_OCR_BAIDU_PRIVATE_AUTH_HEADER="X-Auth-Token"

# Local PaddleOCR project dir and Python interpreter for self-hosted OCR.
POLICY_OCR_PADDLE_PROJECT_DIR=""
POLICY_OCR_PADDLE_PYTHON=""
POLICY_OCR_PADDLE_LANG="ch"
POLICY_OCR_PADDLE_DEVICE="cpu"
POLICY_OCR_PADDLE_DET_MODEL_NAME="PP-OCRv5_mobile_det"
POLICY_OCR_PADDLE_REC_MODEL_NAME="PP-OCRv5_mobile_rec"
POLICY_OCR_PADDLE_USE_DOC_ORIENTATION_CLASSIFY="true"
POLICY_OCR_PADDLE_USE_DOC_UNWARPING="true"
POLICY_OCR_PADDLE_USE_TEXTLINE_ORIENTATION="true"

# Optional local LLM post-processor for OCR text correction/matching.
# Supported: none | ollama_qwen_local
POLICY_OCR_POSTPROCESSOR="none"
POLICY_OCR_OLLAMA_BASE_URL="http://127.0.0.1:11434"
POLICY_OCR_OLLAMA_MODEL="qwen2.5:0.5b"
POLICY_OCR_OLLAMA_VISION_MODEL="qwen2.5vl:3b"
POLICY_OCR_OLLAMA_VISION_NUM_CTX="512"
POLICY_OCR_OLLAMA_TIMEOUT_MS="45000"

# DeepSeek policy analysis
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_FALLBACK_MODEL="deepseek-chat"
DEEPSEEK_TIMEOUT_MS="60000"
# Privacy-first default: only send structured policy fields to DeepSeek, not OCR raw text.
DEEPSEEK_ANALYSIS_INCLUDE_OCR_TEXT="false"
