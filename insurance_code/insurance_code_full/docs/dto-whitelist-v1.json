                "content": { "type": "string" },
                "media": { "type": "array", "item": { "any": true } },
                "videoUrl": { "type": "string" },
                "status": { "type": "string", "optional": true },
                "isPlatformTemplate": { "type": "boolean", "optional": true },
                "templateTag": { "type": "string", "optional": true }
              }
            }
          }
        }
      }
    },
