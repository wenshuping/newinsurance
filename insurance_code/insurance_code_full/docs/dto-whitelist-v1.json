{
  "meta": {
    "version": "v1",
    "updatedAt": "2026-03-04",
    "note": "C端核心读取接口 DTO 字段白名单。allowExtra=false 表示禁止新增未登记字段。"
  },
  "endpoints": [
    {
      "name": "health",
      "method": "GET",
      "path": "/api/health",
      "auth": false,
      "schema": {
        "type": "object",
        "allowExtra": false,
        "required": ["ok", "service"],
        "properties": {
          "ok": { "type": "boolean" },
          "service": { "type": "string" }
        }
      }
    },
    {
      "name": "bootstrap",
      "method": "GET",
      "path": "/api/bootstrap",
      "auth": false,
      "schema": {
        "type": "object",
        "allowExtra": false,
        "required": ["user", "balance", "csrfToken", "tabs"],
        "properties": {
          "user": {
            "type": "object",
            "nullable": true,
            "allowExtra": false,
            "required": ["id", "name", "mobile", "nick_name", "avatar_url", "is_verified_basic", "verified_at"],
            "properties": {
              "id": { "type": "number" },
              "name": { "type": "string" },
              "mobile": { "type": "string" },
              "nick_name": { "type": "string" },
              "avatar_url": { "type": "string" },
              "is_verified_basic": { "type": "boolean" },
              "verified_at": { "type": "string", "nullable": true }
            }
          },
          "balance": { "type": "number" },
          "csrfToken": { "type": "string", "nullable": true },
          "tabs": { "type": "array", "item": { "type": "string" } }
        }
      }
    },
    {
      "name": "verify-basic",
      "method": "POST",
      "path": "/api/auth/verify-basic",
      "auth": false,
      "bodyFromContext": "verifyBasicBody",
      "schema": {
        "type": "object",
        "allowExtra": false,
        "required": ["token", "csrfToken", "user"],
        "properties": {
          "token": { "type": "string" },
          "csrfToken": { "type": "string" },
          "user": {
            "type": "object",
            "allowExtra": false,
            "required": ["id", "name", "mobile", "nick_name", "avatar_url", "is_verified_basic", "verified_at"],
            "properties": {
              "id": { "type": "number" },
              "name": { "type": "string" },
              "mobile": { "type": "string" },
              "nick_name": { "type": "string" },
              "avatar_url": { "type": "string" },
              "is_verified_basic": { "type": "boolean" },
              "verified_at": { "type": "string", "nullable": true }
            }
          }
        }
      }
    },
    {
      "name": "me",
      "method": "GET",
      "path": "/api/me",
      "auth": true,
      "schema": {
        "type": "object",
        "allowExtra": false,
        "required": ["user", "balance", "csrfToken"],
        "properties": {
          "user": {
            "type": "object",
            "allowExtra": false,
            "required": ["id", "name", "mobile", "nick_name", "avatar_url", "is_verified_basic", "verified_at"],
            "properties": {
              "id": { "type": "number" },
              "name": { "type": "string" },
              "mobile": { "type": "string" },
              "nick_name": { "type": "string" },
              "avatar_url": { "type": "string" },
              "is_verified_basic": { "type": "boolean" },
              "verified_at": { "type": "string", "nullable": true }
            }
          },
          "balance": { "type": "number" },
          "csrfToken": { "type": "string", "nullable": true }
        }
      }
    },
    {
      "name": "activities",
      "method": "GET",
      "path": "/api/activities",
      "auth": false,
      "schema": {
        "type": "object",
        "allowExtra": false,
        "required": ["activities", "balance", "taskProgress"],
        "properties": {
          "activities": {
            "type": "array",
            "item": {
              "type": "object",
              "allowExtra": false,
              "required": ["id", "title", "category", "rewardPoints", "sortOrder", "participants", "completed", "canComplete"],
              "properties": {
                "id": { "type": "number" },
                "title": { "type": "string" },
                "category": { "type": "string" },
                "rewardPoints": { "type": "number" },
                "sortOrder": { "type": "number" },
                "participants": { "type": "number" },
                "completed": { "type": "boolean" },
                "canComplete": { "type": "boolean" },
                "image": { "type": "string", "optional": true },
                "cover": { "type": "string", "optional": true },
                "media": { "type": "array", "optional": true, "item": { "any": true } },
                "description": { "type": "string", "optional": true },
                "status": { "type": "string", "optional": true }
              }
            }
          },
          "balance": { "type": "number" },
          "taskProgress": {
            "type": "object",
            "allowExtra": false,
            "required": ["total", "completed"],
            "properties": {
              "total": { "type": "number" },
              "completed": { "type": "number" }
            }
          }
        }
      }
    },
    {
      "name": "points-summary",
      "method": "GET",
      "path": "/api/points/summary",
      "auth": true,
      "schema": {
        "type": "object",
        "allowExtra": false,
        "required": ["balance"],
        "properties": {
          "balance": { "type": "number" }
        }
      }
    },
    {
      "name": "points-detail",
      "method": "GET",
      "path": "/api/points/detail",
      "auth": true,
      "schema": {
        "type": "object",
        "allowExtra": false,
        "required": ["balance", "groups"],
        "properties": {
          "balance": { "type": "number" },
          "groups": {
            "type": "array",
            "item": {
              "type": "object",
              "allowExtra": false,
              "required": ["key", "label", "items"],
              "properties": {
                "key": { "type": "string" },
                "label": { "type": "string" },
                "items": {
                  "type": "array",
                  "item": {
                    "type": "object",
                    "allowExtra": false,
                    "required": ["id", "title", "amount", "direction", "source", "createdAt"],
                    "properties": {
                      "id": { "type": "number" },
                      "title": { "type": "string" },
                      "amount": { "type": "number" },
                      "balance": { "type": "number", "optional": true },
                      "direction": { "type": "string" },
                      "source": { "type": "string" },
                      "createdAt": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
